rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required) - User ID
    //   - personalInfo: map (required) - Personal information
    //   - experience: list (optional) - Work experience
    //   - education: list (optional) - Education history
    //   - skills: list (optional) - Skills
    //   - certifications: list (optional) - Certifications
    //   - languages: list (optional) - Languages
    //   - courses: list (optional) - Courses
    //   - projects: list (optional) - Projects
    //   - geminiApiKey: string (optional) - API key for Gemini
    //   - auditData: map (optional) - Audit data
    //
    // Collection: applications
    // Document ID: {applicationId}
    // Fields:
    //   - uid: string (required) - User ID
    //   - jobUrl: string (optional) - Job URL
    //   - company: string (required) - Company name
    //   - position: string (required) - Position name
    //   - status: string (required) - Status
    //   - tailoredCv: map (optional) - Tailored CV data
    //   - createdAt: timestamp (required) - Creation time
    //   - updatedAt: timestamp (required) - Last update time
    //
    // Collection: test
    // Document ID: connection
    // Fields: None
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
             request.resource.data[field].size() >= minLen &&
             request.resource.data[field].size() <= maxLen;
    }

    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return data.uid is string &&
             data.uid.size() > 0 &&
             data.uid.size() < 100 &&
             data.personalInfo is map &&
             (!('experience' in data) || data.experience is list) &&
             (!('education' in data) || data.education is list) &&
             (!('skills' in data) || data.skills is list) &&
             (!('certifications' in data) || data.certifications is list) &&
             (!('languages' in data) || data.languages is list) &&
             (!('courses' in data) || data.courses is list) &&
             (!('projects' in data) || data.projects is list) &&
             (!('geminiApiKey' in data) || (data.geminiApiKey is string && data.geminiApiKey.size() <= 200)) &&
             (!('auditData' in data) || data.auditData is map);
    }

    function isValidApplication(data) {
      return ('uid' in data) && data.uid is string &&
             data.uid.size() > 0 &&
             data.uid.size() < 100 &&
             (!('company' in data) || data.company == null || (data.company is string && data.company.size() <= 500)) &&
             (!('position' in data) || data.position == null || (data.position is string && data.position.size() <= 500)) &&
             ('status' in data) && data.status in ['prepared', 'applied', 'interviewing', 'offered', 'rejected', 'interview', 'offer'] &&
             (!('createdAt' in data) || data.createdAt is timestamp) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp) &&
             (!('jobUrl' in data) || data.jobUrl == null || (data.jobUrl is string && data.jobUrl.size() <= 2000)) &&
             (!('tailoredCv' in data) || data.tailoredCv == null || data.tailoredCv is map);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /test/connection {
      allow read: if true;
      allow write: if false;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) &&
                    hasRequiredFields(['uid', 'personalInfo']) &&
                    isValidUser(request.resource.data) &&
                    uidUnchanged();
      allow update: if isOwner(userId) &&
                    isValidUser(request.resource.data) &&
                    uidNotModified();
      allow delete: if false;
    }

    match /applications/{applicationId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() &&
                    hasRequiredFields(['uid', 'company', 'position', 'status']) &&
                    isValidApplication(request.resource.data) &&
                    uidUnchanged();
      allow update: if isDocOwner() &&
                    (!('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid) &&
                    (!('createdAt' in request.resource.data) || request.resource.data.createdAt == resource.data.createdAt);
      allow delete: if isDocOwner();
    }

    match /job_cache/{hashId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}
